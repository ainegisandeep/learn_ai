import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.Assert;
import org.testng.annotations.AfterMethod;
import org.testng.annotations.BeforeMethod;
import org.testng.annotations.Test;


public class SimpleLoginTest {


    WebDriver driver;


    @BeforeMethod
    public void setup() {
        System.setProperty("webdriver.chrome.driver", "/path/to/chromedriver");
        driver = new ChromeDriver();
        driver.manage().window().maximize();
        driver.get("https://app.simplelogin.io/auth/login");
    }


    @Test
    public void validLogin() {


        WebElement usernameField = driver.findElement(By.id("email"));
        WebElement passwordField = driver.findElement(By.id("password"));
        WebElement loginButton = driver.findElement(By.id("submit-btn"));


        usernameField.sendKeys("valid_username");
        passwordField.sendKeys("valid_password");


        Assert.assertTrue(loginButton.isEnabled(), "Login button is not enabled");


        loginButton.click();


        // Example post-login validation (Update locator as needed)
        Assert.assertTrue(driver.getCurrentUrl().contains("dashboard"),
                "User is not redirected to dashboard");
    }


    @Test
    public void invalidLogin() {


        driver.findElement(By.id("email")).sendKeys("invalid_username");
        driver.findElement(By.id("password")).sendKeys("invalid_password");
        driver.findElement(By.id("submit-btn")).click();


        WebElement errorMessage =
                driver.findElement(By.xpath("//div[contains(@class,'error')]"));


        Assert.assertTrue(errorMessage.isDisplayed(), "Error message not displayed");
        Assert.assertTrue(errorMessage.getText().contains("Invalid"),
                "Incorrect error message text");
    }


    @Test
    public void emptyUsername() {


        driver.findElement(By.id("password")).sendKeys("valid_password");
        driver.findElement(By.id("submit-btn")).click();


        WebElement errorMessage =
                driver.findElement(By.xpath("//div[contains(@class,'error')]"));


        Assert.assertTrue(errorMessage.isDisplayed());
        Assert.assertTrue(errorMessage.getText().contains("Email"));
    }


    @Test
    public void emptyPassword() {


        driver.findElement(By.id("email")).sendKeys("valid_username");
        driver.findElement(By.id("submit-btn")).click();


        WebElement errorMessage =
                driver.findElement(By.xpath("//div[contains(@class,'error')]"));


        Assert.assertTrue(errorMessage.isDisplayed());
        Assert.assertTrue(errorMessage.getText().contains("Password"));
    }


    @AfterMethod
    public void tearDown() {
        driver.quit();
    }
}

